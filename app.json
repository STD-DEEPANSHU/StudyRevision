{
  "name": "AI Medical Revision Bot",
  "description": "Fully automatic AI-powered Telegram study bot with revision, memory, and chatbot (English + Hindi)",
  "repository": "https://github.com/YOUR_USERNAME/auto-revision-bot",
  "keywords": [
    "telegram",
    "bot",
    "ai",
    "revision",
    "medical",
    "education",
    "mongodb",
    "automation"
  ],
  "env": {
    "BOT_TOKEN": {
      "description": "Telegram Bot Token from BotFather",
      "required": true
    },
    "MONGO_URI": {
      "description": "MongoDB connection string (Atlas)",
      "required": true
    }
  },
  "formation": {
    "worker": {
      "quantity": 1,
      "size": "basic"
    }
  },
  "buildpacks": [
    {
      "url": "heroku/python"
    }
  ]
}
